{
  "$schema": "Frontier Firm Report Schema v2 — Simplified",
  "description": "11 metrics across 3 signals (Reach, Habit, Skill). Value is narrative only, not scored. Frontier thresholds are deliberately stretching — most organisations will be Foundation or Expansion.",

  "signals": {
    "reach": {
      "label": "Reach",
      "question": "How broadly is it adopted?",
      "color": "#0EA5E9",
      "metrics": ["license_activation", "agent_adoption", "license_coverage", "org_penetration"]
    },
    "habit": {
      "label": "Habit",
      "question": "Is it embedded in daily work?",
      "color": "#F59E0B",
      "metrics": ["embedded_user_rate", "retention_3mo", "habitual_rate"]
    },
    "skill": {
      "label": "Skill",
      "question": "Is it going deep?",
      "color": "#7B2FF2",
      "metrics": ["app_surface_breadth", "agent_breadth", "complex_sessions", "agent_health"]
    }
  },

  "metrics": {
    "license_activation": {
      "name": "License Activation",
      "unit": "% seats active",
      "bands": [60, 85],
      "band_labels": ["Foundation", "Expansion", "Frontier"],
      "signal": "reach",
      "data_field": "m365_enablement",
      "description": "licensed_users / total_licensed_seats * 100"
    },
    "agent_adoption": {
      "name": "Agent Adoption",
      "unit": "% of active users using agents",
      "bands": [10, 25],
      "band_labels": ["Foundation", "Expansion", "Frontier"],
      "signal": "reach",
      "data_field": "agent_adoption",
      "description": "agent_users / total_active_users * 100"
    },
    "license_coverage": {
      "name": "License Coverage",
      "unit": "% of active users licensed",
      "bands": [25, 60],
      "band_labels": ["Foundation", "Expansion", "Frontier"],
      "signal": "reach",
      "data_field": "license_coverage",
      "description": "licensed_users / total_active_users * 100"
    },
    "org_penetration": {
      "name": "Org Penetration",
      "unit": "% orgs with licensed + agents",
      "bands": [20, 50],
      "band_labels": ["Foundation", "Expansion", "Frontier"],
      "signal": "reach",
      "data_field": "org_penetration_pct",
      "description": "% of active orgs where BOTH licensed Copilot users AND agent users are present"
    },

    "embedded_user_rate": {
      "name": "Habitual User Rate",
      "unit": "% habitual users",
      "bands": [15, 35],
      "band_labels": ["Foundation", "Expansion", "Frontier"],
      "signal": "habit",
      "data_field": "embedded_user_rate",
      "description": "Users with avg 6+ active days/month over last 3 months AND present in 2/3 months"
    },
    "retention_3mo": {
      "name": "3-Month Retention",
      "unit": "% avg MoM retention",
      "bands": [70, 88],
      "band_labels": ["Foundation", "Expansion", "Frontier"],
      "signal": "habit",
      "data_field": "m365_retention",
      "description": "Average month-over-month user retention across last 3 complete months"
    },
    "habitual_rate": {
      "name": "Habitual User Rate",
      "unit": "% with 11+ active days",
      "bands": [15, 35],
      "band_labels": ["Foundation", "Expansion", "Frontier"],
      "signal": "habit",
      "data_field": "m365_frequency",
      "description": "Percentage of licensed users with 11+ active days last month"
    },

    "app_surface_breadth": {
      "name": "App Surface Breadth",
      "unit": "apps/user",
      "bands": [3, 5],
      "band_labels": ["Foundation", "Expansion", "Frontier"],
      "signal": "skill",
      "data_field": "m365_breadth",
      "description": "Avg distinct M365 apps/surfaces per user"
    },
    "agent_breadth": {
      "name": "Agent Breadth",
      "unit": "agents/user",
      "bands": [2, 4],
      "band_labels": ["Foundation", "Expansion", "Frontier"],
      "signal": "skill",
      "data_field": "agent_breadth",
      "description": "Avg distinct agents per user"
    },
    "complex_sessions": {
      "name": "Multi-Turn Sessions",
      "unit": "% multi-turn",
      "bands": [40, 70],
      "band_labels": ["Foundation", "Expansion", "Frontier"],
      "signal": "skill",
      "data_field": "complex_sessions",
      "description": "Percentage of sessions with multiple conversational turns"
    },
    "agent_health": {
      "name": "Agent Return Rate",
      "unit": "% return rate (multi-user agents only)",
      "bands": [50, 80],
      "band_labels": ["Foundation", "Expansion", "Frontier"],
      "signal": "skill",
      "data_field": "agent_health",
      "description": "Return rate for multi-user agents only (agents with 2+ distinct users). Single-user agents are excluded as they inflate the metric."
    }
  },

  "pattern_rules": {
    "description": "Pattern determined by signal tiers, not individual metrics. Each signal scores Foundation/Expansion/Frontier based on its metrics. Pattern requires strong performance across ALL signals.",
    "p1_foundation": "Any signal at Foundation",
    "p2_expansion": "All signals at Expansion+, with at most 1 at Frontier",
    "p3_frontier": "All 3 signals at Expansion+, with 2+ at Frontier"
  },

  "insight_blocks": [
    "EXEC_SUMMARY_GOOD",
    "EXEC_SUMMARY_GAP",
    "EXEC_SUMMARY_OPP",
    "INSIGHT_REACH",
    "INSIGHT_HABIT",
    "INSIGHT_SKILL",
    "SPOTLIGHT_MATURITY",
    "PULLQUOTE_0",
    "PULLQUOTE_1",
    "PULLQUOTE_2",
    "PULLQUOTE_3",
    "REC_1_TITLE",
    "REC_1_DESC",
    "REC_2_TITLE",
    "REC_2_DESC",
    "REC_3_TITLE",
    "REC_3_DESC",
    "TITLE_REACH",
    "TITLE_HABIT",
    "TITLE_SKILL",
    "TITLE_VALUE",
    "TITLE_MATURITY",
    "SUBTITLE_REACH",
    "SUBTITLE_HABIT",
    "SUBTITLE_SKILL",
    "SUBTITLE_VALUE",
    "SUBTITLE_MATURITY"
  ],

  "derived_metrics": {
    "time_saved_realised": "licensed_users * licensed_avg_prompts * 6 / 60 * 12",
    "time_saved_unrealised": "inactive_licenses * licensed_avg_prompts * 6 / 60 * 12",
    "activation_rate": "licensed_users / total_licensed_seats * 100"
  }
}
