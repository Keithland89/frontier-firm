{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Frontier Firm Data Schema",
  "description": "Required fields for the Frontier Firm report generator. Every field must be present with a valid value or set to \"not_available\".",
  "type": "object",
  "required": [
    "customer_name",
    "analysis_period",
    "total_active_users",
    "licensed_users",
    "chat_users",
    "agent_users",
    "total_licensed_seats",
    "inactive_licenses",
    "m365_enablement",
    "m365_adoption",
    "agent_adoption",
    "agent_enablement",
    "org_count",
    "license_priority",
    "m365_frequency",
    "chat_habit",
    "agent_frequency",
    "m365_retention",
    "chat_retention",
    "agent_retention",
    "m365_intensity",
    "chat_intensity",
    "agent_intensity",
    "licensed_avg_prompts",
    "unlicensed_avg_prompts",
    "weekly_m365",
    "weekly_chat",
    "weekly_agents",
    "m365_breadth",
    "agent_breadth",
    "complex_sessions",
    "agent_health",
    "agent_creators_pct",
    "license_coverage",
    "agent_habitual",
    "band_1_5",
    "band_6_10",
    "band_11_15",
    "band_16_plus",
    "band_1_5_pct",
    "band_6_10_pct",
    "band_11_15_pct",
    "band_16_plus_pct",
    "chat_band_1_5_pct",
    "chat_band_6_10_pct",
    "chat_band_11_15_pct",
    "chat_band_16_plus_pct",
    "agent_band_1_5_pct",
    "agent_band_6_10_pct",
    "agent_band_11_15_pct",
    "agent_band_16_plus_pct",
    "total_agents",
    "multi_user_agents",
    "agents_keep",
    "agents_review",
    "agents_retire",
    "agent_table",
    "top_agent_names",
    "top_agent_sessions",
    "radar_reach",
    "radar_habit",
    "radar_skill",
    "org_scatter_data",
    "retained_users",
    "churned_users",
    "concentration_index",
    "agent_habitual_rate",
    "org_penetration_pct",
    "embedded_user_rate",
    "licensed_avg_days",
    "unlicensed_avg_days"
  ],
  "properties": {
    "customer_name": { "type": "string", "minLength": 1 },
    "analysis_period": { "type": "string", "minLength": 1 },

    "total_active_users": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "licensed_users": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "chat_users": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agent_users": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "total_licensed_seats": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "inactive_licenses": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },

    "m365_enablement": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "m365_adoption": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agent_adoption": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agent_enablement": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "org_count": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "license_priority": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },

    "m365_frequency": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "chat_habit": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agent_frequency": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "m365_retention": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "chat_retention": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agent_retention": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },

    "m365_intensity": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "chat_intensity": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agent_intensity": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "licensed_avg_prompts": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "unlicensed_avg_prompts": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "weekly_m365": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "weekly_chat": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "weekly_agents": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },

    "m365_breadth": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agent_breadth": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "complex_sessions": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agent_health": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agent_creators_pct": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "license_coverage": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agent_habitual": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },

    "band_1_5": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "band_6_10": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "band_11_15": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "band_16_plus": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "band_1_5_pct": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "band_6_10_pct": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "band_11_15_pct": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "band_16_plus_pct": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },

    "chat_band_1_5_pct": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "chat_band_6_10_pct": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "chat_band_11_15_pct": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "chat_band_16_plus_pct": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },

    "agent_band_1_5_pct": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agent_band_6_10_pct": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agent_band_11_15_pct": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agent_band_16_plus_pct": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },

    "total_agents": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "multi_user_agents": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agents_keep": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agents_review": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "agents_retire": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },

    "agent_table": {
      "oneOf": [
        { "type": "array", "minItems": 1, "items": {
          "type": "object",
          "required": ["name", "type", "users", "sessions", "sessions_per_user"],
          "properties": {
            "name": { "type": "string" },
            "type": { "type": "string" },
            "users": { "type": "number" },
            "sessions": { "type": "number" },
            "sessions_per_user": { "type": "number" }
          }
        }},
        { "const": "not_available" }
      ]
    },
    "top_agent_names": {
      "oneOf": [
        { "type": "array", "minItems": 1, "items": { "type": "string" } },
        { "const": "not_available" }
      ]
    },
    "top_agent_sessions": {
      "oneOf": [
        { "type": "array", "minItems": 1, "items": { "type": "number" } },
        { "const": "not_available" }
      ]
    },

    "radar_reach": {
      "oneOf": [
        { "type": "array", "minItems": 1, "items": { "type": "number" } },
        { "const": "not_available" }
      ]
    },
    "radar_habit": {
      "oneOf": [
        { "type": "array", "minItems": 1, "items": { "type": "number" } },
        { "const": "not_available" }
      ]
    },
    "radar_skill": {
      "oneOf": [
        { "type": "array", "minItems": 1, "items": { "type": "number" } },
        { "const": "not_available" }
      ]
    },

    "org_scatter_data": {
      "oneOf": [
        { "type": "array", "minItems": 1, "items": {
          "type": "object",
          "required": ["label", "x", "y", "r"],
          "properties": {
            "label": { "type": "string" },
            "x": { "type": "number" },
            "y": { "type": "number" },
            "r": { "type": "number" }
          }
        }},
        { "const": "not_available" }
      ]
    },

    "retained_users": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },
    "churned_users": { "oneOf": [{ "type": "number", "minimum": 0 }, { "const": "not_available" }] },

    "_supplementary_metrics": {
      "type": "object",
      "properties": {
        "monthly_data": { "type": "object" },
        "per_tier_monthly_users": { "type": "array", "minItems": 1 },
        "per_tier_active_day_bands": { "type": "array", "minItems": 1 },
        "app_interactions": { "type": "object" },
        "distinct_departments": { "type": "number" },
        "retention_cohorts": { "type": "object" },
        "per_tier_retention_cohorts": { "type": "array" }
      }
    }
  },
  "additionalProperties": true
}
